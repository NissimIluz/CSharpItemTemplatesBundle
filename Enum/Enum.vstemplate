<VSTemplate Version="3.0.0" Type="Item"
 xmlns="http://schemas.microsoft.com/developer/vstemplate/2005">
  <TemplateData>
    <Name>Enum</Name>
    <Description>Creates a public enum with file-scoped namespace.</Description>
    <ProjectType>CSharp</ProjectType>
    <DefaultName>MyEnum.cs</DefaultName>
    <SortOrder>30</SortOrder>
  </TemplateData>
  <TemplateContent>
    <ProjectItem ReplaceParameters="true">EnumTemplate.cs</ProjectItem>
  </TemplateContent>
</VSTemplate>
