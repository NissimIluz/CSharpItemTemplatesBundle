<VSTemplate Version="3.0.0" Type="Item"
 xmlns="http://schemas.microsoft.com/developer/vstemplate/2005">
  <TemplateData>
    <Name>Record</Name>
    <Description>Creates a public record with file-scoped namespace.</Description>
